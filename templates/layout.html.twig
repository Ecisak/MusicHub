<!doctype html>
<html lang="cs">
<head>
    <!-- Character Encoding and Viewport -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../public/css/style.css">

    <!-- Page Title -->
    <title>MusicHub - Domovská stránka</title>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="../public/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="../public/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="../public/images/favicon-16x16.png">
    <link rel="manifest" href="../public/images/site.webmanifest">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png">
    <meta name="theme-color" content="#ffffff">
</head>
<body>

<!-- Background Container -->
<div class="background">
    {% if flashMessage %}
        <div class="alert alert-info" role="alert">
            {{ flashMessage }}
        </div>
        {% endif %}
        <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" href="/MusicHub/public/index.php?page=home">
                <img class=logo src="../public/images/MusicHub..svg" alt="MusicHub Logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item my-nav"><a class="nav-link active" href="/MusicHub/public/index.php?page=home">Domů</a>
                    </li>
                    <li class="nav-item my-nav"><a class="nav-link" href="/MusicHub/public/index.php?page=leaderboard">Žebříček</a>
                    </li>
                    <li class="nav-item my-nav"><a class="nav-link" href="/MusicHub/public/index.php?page=add">Přidat Hudbu</a></li>
                    <li class="nav-item my-nav"><a class="nav-link" href="/MusicHub/public/index.php?page=explore">Prohlížet Hudbu</a></li>
                    <li class="nav-item my-nav"><a class="nav-link" href="/MusicHub/public/index.php?page=about">O nás</a></li>
                    {% if role == 'reviewer' and pending_songs_count > 0 %}
                    <li class="nav-item my-nav">
                        <a class="nav-link" href="/MusicHub/public/index.php?page=review">
                            Validace
                            <span class="badge bg-danger">{{  pending_songs_count }}</span>
                        </a>
                    </li>
                    {% endif %}

                </ul>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            {% if not isLoggedIn%}
                                <li class="nav-item">
                                    <a class="btn btn-primary my-btn2 me-2" href="/MusicHub/public/index.php?page=login" role="button">Přihlásit se</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary my-btn2" href="/MusicHub/public/index.php?page=register" role="button">Registrovat se</a>
                                </li>

                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link"><div>Přihlášen: {{ username }}</div></a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary my-btn2 " href="/MusicHub/public/index.php?page=logout">Odhlásit se</a>
                                </li>
                            {% endif %}
                        </ul>
            </div>
        </div>


    </nav>


    {% block content %}
    {% endblock %}
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

<!-- Footer -->
<footer class="footer">
    made with <p class="hearts">&hearts;</p> by <a class="footer-link" href="#">Ecis</a>
</footer>
</html>