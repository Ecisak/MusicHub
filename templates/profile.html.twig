{% extends 'layout.html.twig' %}
{% block title %}Můj profil{% endblock %}
{% block content %}
    <div class="container mt-4">
        <h2>Moje hudba</h2>

        <!-- Check if the user has uploaded any songs -->
        {% if mySongs is empty %}
            <div class="alert alert-info">Zatím jsi nenahrál žádnou hudbu.</div>
        {% else %}
            <!-- Grid for displaying user's uploaded songs -->
            <div class="row row-cols-1 row-cols-md-3 g-4">
                {% for song in mySongs %}
                    <div class="col">
                        <div class="card shadow-sm h-100">

                            <!-- Song Cover Image -->
                            <div style="height: 200px; overflow: hidden;">
                                <img src="/MusicHub/public/uploads/covers/{{ song.cover_image }}" class="card-img-top h-100 w-100" style="object-fit: cover;" alt="{{ song.title }}">
                            </div>

                            <div class="card-body">
                                <h5 class="card-title text-truncate">{{ song.title }}</h5>
                                <p class="card-text text-muted small mb-2">{{ song.author }}</p>

                                <!-- Song Status Badge -->
                                <div class="mb-2">
                                    {% if song.status == 'accepted' %}
                                        <span class="badge bg-success">Schváleno</span>
                                    {% elseif song.status == 'rejected' %}
                                        <span class="badge bg-danger">Zamítnuto</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Čeká na schválení</span>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Audio Player in Footer -->
                            <div class="card-footer bg-white border-top-0">
                                <audio controls class="w-100" src="/MusicHub/public/uploads/music/{{ song.filename }}"></audio>
                            </div>

                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <!-- Reviewer Section: Display My Reviews -->
        {% if userRole == 'reviewer' %}

            <h2 class="mt-5">Moje Recenze</h2> <!-- Section heading for reviews -->

            <!-- Check if the reviewer has written any reviews -->
            {% if myReviews is empty %}
                <div class="alert alert-info">Zatím jsi nenapsal žádnou recenzi.</div>
            {% else %}

                <!-- Grid for displaying user's reviews -->
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    {% for review in myReviews %}
                        <div class="col">
                            <div class="card shadow-sm h-100">

                                <!-- Link to song detail page with cover image -->
                                <a href="/MusicHub/public/index.php?page=song&id={{ review.id_song }}">
                                    <div style="height: 200px; overflow: hidden;">
                                        <img src="/MusicHub/public/uploads/covers/{{ review.cover_image }}" class="card-img-top h-100 w-100" style="object-fit: cover;" alt="{{ review.song_title }}">
                                    </div>
                                </a>

                                <div class="card-body d-flex flex-column"> <!-- Flexbox to push buttons to the bottom -->
                                    <h5 class="card-title text-truncate">{{ review.song_title }}</h5>
                                    <p class="card-text text-muted small mb-2">{{ review.author }}</p>

                                    <hr>

                                    <!-- Review Comment Snippet -->
                                    <div class="card-text small text-secondary fst-italic mb-3">
                                        "{{ review.comment | striptags | slice(0, 100) }}..."
                                    </div>

                                    <!-- Status and Actions (aligned to the bottom) -->
                                    <div class="mt-auto">
                                        {% if review.status == 'approved' %}
                                            <span class="badge bg-success">Schváleno</span>
                                        {% elseif review.status == 'rejected' %}
                                            <span class="badge bg-danger">Zamítnuto</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">Čeká na schválení</span>

                                            <!-- Edit and Delete Actions for pending reviews -->
                                            <div class="mt-2 pt-2 border-top d-flex gap-2">
                                                <!-- Edit Button -->
                                                <a href="/MusicHub/public/index.php?page=edit_review&id={{ review.id_review }}" class="btn btn-sm btn-outline-primary w-50">
                                                    Upravit
                                                </a>
                                                <!-- Delete Form -->
                                                <form action="/MusicHub/public/index.php?page=delete_review" method="POST" class="w-50" onsubmit="return confirm('Opravdu smazat tuto recenzi?');">
                                                    <input type="hidden" name="review_id" value="{{ review.id_review }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Smazat</button>
                                                </form>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>


                    {% endfor %}
                </div> <!-- End Review Grid -->
            {% endif %}

        {% endif %}
    </div>
{% endblock %}