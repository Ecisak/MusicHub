{% extends 'layout.html.twig' %}
{% block title %}Schvalování skladeb{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <!-- Karta pro validaci -->
                <div class="card shadow">

                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Validace skladby</h4>
                    </div>

                    <div class="card-body text-center p-4">

                        <p class="lead mb-4">Splňuje písnička veškerá pravidla?</p>

                        <!-- Obrázek alba -->
                        <div class="mb-4">
                            <img src="/MusicHub/public/uploads/covers/{{ song.cover_image }}"
                                 alt="Cover"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-height: 300px; width: auto; object-fit: cover;">
                        </div>

                        <!-- Informace -->
                        <h3 class="fw-bold">{{ song.title }}</h3>
                        <p class="text-muted fs-5 mb-4">{{ song.author }}</p>

                        <!-- Přehrávač -->
                        <div class="mb-4 bg-light p-3 rounded">
                            <audio controls class="w-100" src="/MusicHub/public/uploads/music/{{ song.filename }}"></audio>
                        </div>

                        <!-- Tlačítka -->
                        <form method="post" action="/MusicHub/public/index.php?page=process_validation">
                            <input type="hidden" name="id" value="{{ song.id_song }}">

                            <div class="d-flex gap-3 justify-content-center">
                                <button type="submit" name="action" value="reject" class="btn btn-outline-danger btn-lg px-4">
                                    Zamítnout
                                </button>

                                <button type="submit" name="action" value="approve" class="btn btn-success btn-lg px-5">
                                    Přijmout
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}